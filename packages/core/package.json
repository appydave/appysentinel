{
  "name": "@appydave/appysentinel-core",
  "version": "0.3.0",
  "description": "AppySentinel runtime library — Signal envelope, event bus, createSentinel(); shared primitives (lifecycle, config, atomic write, serial queue, logger) re-exported from @appydave/core",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./signal": {
      "types": "./dist/signal.d.ts",
      "import": "./dist/signal.js"
    },
    "./bus": {
      "types": "./dist/bus.d.ts",
      "import": "./dist/bus.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'core lint stub' && exit 0",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@appydave/core": "^0.1.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "appydave",
    "appysentinel",
    "sentinel",
    "telemetry",
    "observability",
    "collector",
    "signal",
    "bun",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appydave/appysentinel.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/appydave/appysentinel#readme",
  "author": "David Cruwys",
  "license": "MIT"
}
